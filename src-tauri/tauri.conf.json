{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoMind",
  "version": "0.3.0",
  "identifier": "com.fu-qianchen.echomind",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EchoMind",
        "width": 960,
        "height": 700,
        "minWidth": 680,
        "minHeight": 500,
        "center": true,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "capture",
        "title": "EchoMind 速记",
        "url": "index.html?capture=1",
        "width": 560,
        "height": 180,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPDATA/../**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
