{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoMind",
  "version": "0.3.7",
  "identifier": "com.fu-qianchen.echomind",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build && node scripts/build-sidecars.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EchoMind",
        "width": 960,
        "height": 700,
        "minWidth": 680,
        "minHeight": 500,
        "center": true,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "capture",
        "title": "EchoMind 速记",
        "url": "index.html?capture=1",
        "width": 560,
        "height": 180,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPDATA/../**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/echomind-server",
      "binaries/echomind-wechat-bot"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Qc-riviere/EchoMind-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzQjU3N0QzNDk5QUEzNTkKUldSWm81cEowM2UxTXc4NFRoK1RhNWxHcm94T0RoNTd0VCt2dzBXN3hmTXExTWZGUjdUNUg2RDIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
