# ── Required secrets ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
BRIDGE_JWT_SECRET=

# Generate with: openssl rand -hex 20
BRIDGE_ADMIN_TOKEN=

# Generate with: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
BRIDGE_ENCRYPTION_KEY=

# ── Domain (used by nginx + certbot) ─────────────────────────────────────────
DOMAIN=bridge.example.com

# ── Bot (set after pairing the desktop EchoMind to this bridge) ──────────────
# Get the token from: POST /bridge/pair (called automatically by the desktop app)
# Then paste the returned JWT here so the VPS bot can authenticate.
ECHOMIND_BRIDGE_TOKEN=
